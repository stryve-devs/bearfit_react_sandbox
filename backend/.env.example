# Copy this file to `.env` in the same folder and replace placeholder values.
# Never commit real secrets.

# PostgreSQL connection string used by Prisma.
DATABASE_URL=postgres://username:password@host:5432/database?sslmode=require

# Redis connection URL for caching/session/OTP storage.
REDIS_URL=redis://redis:6379

# Secret key used to sign JWT access tokens (use a long random string).
JWT_ACCESS_SECRET=replace-with-a-long-random-secret

# Secret key used to sign JWT refresh tokens (use a different long random string).
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret

# Access token lifetime (examples: 15m, 1h).
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token lifetime (examples: 7d, 30d).
JWT_REFRESH_EXPIRES_IN=7d

# API server port.
PORT=3001

# Runtime mode: development | test | production
NODE_ENV=development

# Google OAuth Web client ID from Google Cloud Console.
GOOGLE_CLIENT_ID_WEB=your-google-web-client-id.apps.googleusercontent.com

