# Copy this file to `.env` in the same folder and replace placeholder values.
# Do not commit real credentials.

# Public URL base for assets (usually your Cloudflare R2 public dev URL).
EXPO_PUBLIC_R2_PUBLIC_URL=https://your-public-bucket-url.r2.dev

# R2 S3-compatible endpoint URL for your account.
EXPO_PUBLIC_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# R2 access key ID with permission to access the bucket.
EXPO_PUBLIC_R2_ACCESS_KEY_ID=your-access-key-id

# R2 secret access key paired with the access key ID.
EXPO_PUBLIC_R2_SECRET_ACCESS_KEY=your-secret-access-key

# R2 bucket name used by the frontend.
EXPO_PUBLIC_R2_BUCKET_NAME=your-bucket-name

# Cloudflare account ID that owns the R2 bucket.
EXPO_PUBLIC_R2_ACCOUNT_ID=your-account-id

