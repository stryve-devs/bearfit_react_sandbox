{
  "name": "bearfit-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "./dev.sh",
    "install-all": "npm install",
    "be:prisma": "npm run prisma:generate -w backend",
    "fe:start": "npm start -w frontend",
    "upload:videos:r2": "bash uploadvideostoR2.sh",
    "upload:videos:r2:dry": "bash uploadvideostoR2.sh --dry-run"
  },
  "dependencies": {
    "expo": "^54.0.33",
    "expo-blur": "~15.0.8",
    "expo-font": "~14.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.10"
  }
}
